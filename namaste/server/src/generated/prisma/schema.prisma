// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NAMASTE Code model - stores all AYUSH system terminology
model NAMASTECode {
  id         String   @id @default(cuid())
  code       String
  display    String
  definition String?
  system     String // 'ayurveda' | 'siddha' | 'unani'
  language   String   @default("en")
  synonyms   String[] // Array of synonym terms
  parent     String? // Parent code for hierarchy
  status     String   @default("active")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Ensure unique codes per system
  @@unique([system, code])
  @@index([system])
  @@index([display])
  @@index([code])
  @@map("namaste_codes")
}

// Processing statistics tracking
model ProcessingStats {
  id           String    @id @default(cuid())
  system       String    @unique // 'ayurveda' | 'siddha' | 'unani'
  totalRecords Int       @default(0)
  validRecords Int       @default(0)
  lastUpload   DateTime?
  lastUpdated  DateTime  @updatedAt
  createdAt    DateTime  @default(now())

  @@map("processing_stats")
}

// WHO ICD-11 codes cache (for future mapping)
model WHOCode {
  id         String   @id
  entityId   String   @unique
  title      String
  definition String?
  system     String   @default("ICD-11")
  language   String   @default("en")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([entityId])
  @@map("who_codes")
}
